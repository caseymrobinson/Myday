# Google Calendar iCal URL (secret URL from Google Calendar)
ICS_URL=https://calendar.google.com/calendar/ical/your-calendar-id/basic.ics

# OpenAI API Key (optional - for AI features)
OPENAI_API_KEY=your-openai-api-key-here

# Server port (defaults to 5000 if not set)
PORT=5000

# Database URL (for production with PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/myday
